# API / worker local runtime contract (`make api` and `make worker` both auto-load this file via `.env`)
SOURCEBOT_SERVICE_NAME=sourcebot-api
SOURCEBOT_BIND_ADDR=127.0.0.1:3000
RUST_LOG=info

# Shared local file-backed runtime state base directory
SOURCEBOT_DATA_DIR=.sourcebot

# Optional per-file overrides; leave commented to use SOURCEBOT_DATA_DIR defaults
# SOURCEBOT_BOOTSTRAP_STATE_PATH=.sourcebot/bootstrap-state.json
# SOURCEBOT_LOCAL_SESSION_STATE_PATH=.sourcebot/local-sessions.json
# SOURCEBOT_ORGANIZATION_STATE_PATH=.sourcebot/organizations.json

# Optional worker stub controls for the current one-shot runtime baseline
# SOURCEBOT_STUB_REVIEW_AGENT_RUN_EXECUTION_OUTCOME=completed
# SOURCEBOT_STUB_REPOSITORY_SYNC_JOB_EXECUTION_OUTCOME=succeeded

# Database (deterministic local-dev defaults that match docker-compose.yml)
DATABASE_URL=postgres://sourcebot:sourcebot@127.0.0.1:5432/sourcebot
TEST_DATABASE_URL=postgres://sourcebot:sourcebot@127.0.0.1:5432/sourcebot_test
POSTGRES_DB=sourcebot
POSTGRES_USER=sourcebot
POSTGRES_PASSWORD=sourcebot
